{
  "schema_name": "adelin_v2_manual_trade_evidence_schema",
  "schema_version": "1.1",
  "intended_use": "manual qualitative evidence collection",
  "schema_only": true,
  "validation_claim": "none",
  "phase_4_blocked": true,
  "fields": [
    {"name": "evidence_id", "category": "identity", "required_column": true, "required_for_nonblank_row": true, "type": "string"},
    {"name": "example_only", "category": "identity", "required_column": true, "required_for_nonblank_row": true, "type": "boolean", "allowed_values": ["true", "false"]},
    {"name": "capture_mode", "category": "identity", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["RAPID_CAPTURE", "FULL_REVIEW"]},
    {"name": "source_person", "category": "identity", "required_column": true, "required_for_nonblank_row": true, "type": "string"},
    {"name": "source_channel", "category": "identity", "required_column": true, "required_for_nonblank_row": true, "type": "string"},
    {"name": "screenshot_path", "category": "identity", "required_column": true, "required_for_nonblank_row": true, "type": "string"},
    {"name": "screenshot_count", "category": "identity", "required_column": true, "required_for_nonblank_row": false, "type": "integer"},
    {"name": "symbol", "category": "identity", "required_column": true, "required_for_nonblank_row": true, "type": "string"},
    {"name": "instrument_class", "category": "identity", "required_column": true, "required_for_nonblank_row": false, "type": "string"},
    {"name": "date_observed", "category": "identity", "required_column": true, "required_for_nonblank_row": false, "type": "string"},
    {"name": "approximate_trade_time", "category": "identity", "required_column": true, "required_for_nonblank_row": false, "type": "string"},
    {"name": "timezone", "category": "identity", "required_column": true, "required_for_nonblank_row": false, "type": "string"},
    {"name": "platform", "category": "identity", "required_column": true, "required_for_nonblank_row": false, "type": "string"},
    {"name": "timeframe_primary", "category": "identity", "required_column": true, "required_for_nonblank_row": false, "type": "string"},
    {"name": "timeframes_available", "category": "identity", "required_column": true, "required_for_nonblank_row": false, "type": "string"},
    {"name": "screenshot_quality", "category": "identity", "required_column": true, "required_for_nonblank_row": false, "type": "string"},

    {"name": "direction", "category": "trade", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["LONG", "SHORT", "UNKNOWN"]},
    {"name": "entry_price", "category": "trade", "required_column": true, "required_for_nonblank_row": false, "type": "string"},
    {"name": "stop_loss_price", "category": "trade", "required_column": true, "required_for_nonblank_row": false, "type": "string"},
    {"name": "take_profit_price", "category": "trade", "required_column": true, "required_for_nonblank_row": false, "type": "string"},
    {"name": "target_price", "category": "trade", "required_column": true, "required_for_nonblank_row": false, "type": "string"},
    {"name": "position_size_if_visible", "category": "trade", "required_column": true, "required_for_nonblank_row": false, "type": "string"},
    {"name": "trade_status_if_visible", "category": "trade", "required_column": true, "required_for_nonblank_row": false, "type": "string"},
    {"name": "profit_loss_if_visible", "category": "trade", "required_column": true, "required_for_nonblank_row": false, "type": "string"},
    {"name": "result_known", "category": "trade", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["YES", "NO", "PARTIAL", "UNKNOWN"]},
    {"name": "result_label", "category": "trade", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["GOOD_FAST_REACTION", "FAST_FAILURE", "MIXED_REACTION", "CHOP_AFTER_ENTRY", "WIN", "LOSS", "BREAKEVEN", "UNKNOWN", "NOT_APPLICABLE"]},

    {"name": "liquidity_sweep_present", "category": "context", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["YES", "NO", "UNCLEAR", "NOT_APPLICABLE"]},
    {"name": "liquidity_sweep_side", "category": "context", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["HIGH", "LOW", "BOTH", "UNKNOWN", "NOT_APPLICABLE"]},
    {"name": "swing_high_low_context", "category": "context", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["YES", "NO", "UNCLEAR", "NOT_APPLICABLE"]},
    {"name": "volume_profile_present", "category": "context", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["YES", "NO", "UNCLEAR", "NOT_APPLICABLE"]},
    {"name": "volume_profile_level_type", "category": "context", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["POC", "HVN", "LVN", "VALUE_AREA_HIGH", "VALUE_AREA_LOW", "UNKNOWN", "NOT_APPLICABLE"]},
    {"name": "htf_level_present", "category": "context", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["YES", "NO", "UNCLEAR", "NOT_APPLICABLE"]},
    {"name": "htf_timeframe", "category": "context", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["H1", "H4", "D1", "W1", "UNKNOWN", "NOT_APPLICABLE"]},
    {"name": "round_level_present", "category": "context", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["YES", "NO", "UNCLEAR", "NOT_APPLICABLE"]},
    {"name": "fvg_ifvg_present", "category": "context", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["YES", "NO", "UNCLEAR", "NOT_APPLICABLE"]},
    {"name": "target_space_clean", "category": "context", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["YES", "NO", "UNCLEAR", "NOT_APPLICABLE"]},
    {"name": "immediate_reaction_present", "category": "context", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["YES", "NO", "UNCLEAR", "NOT_APPLICABLE"]},
    {"name": "reaction_speed", "category": "context", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["FAST", "SLOW", "CHOPPY", "NONE", "UNKNOWN", "NOT_APPLICABLE"]},

    {"name": "human_entry_reason", "category": "human_reasoning", "required_column": true, "required_for_nonblank_row": false, "type": "text"},
    {"name": "human_no_trade_reason", "category": "human_reasoning", "required_column": true, "required_for_nonblank_row": false, "type": "text"},
    {"name": "human_notes", "category": "human_reasoning", "required_column": true, "required_for_nonblank_row": false, "type": "text"},
    {"name": "what_human_saw", "category": "human_reasoning", "required_column": true, "required_for_nonblank_row": false, "type": "text"},
    {"name": "what_bot_might_miss", "category": "human_reasoning", "required_column": true, "required_for_nonblank_row": false, "type": "text"},
    {"name": "discretionary_elements", "category": "human_reasoning", "required_column": true, "required_for_nonblank_row": false, "type": "text"},
    {"name": "confidence_human_label", "category": "human_reasoning", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["0", "1", "2", "3"]},

    {"name": "metadata_complete", "category": "data_quality", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["YES", "NO", "PARTIAL"]},
    {"name": "price_levels_visible", "category": "data_quality", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["YES", "NO", "PARTIAL"]},
    {"name": "timestamp_visible", "category": "data_quality", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["YES", "NO", "PARTIAL"]},
    {"name": "outcome_visible", "category": "data_quality", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["YES", "NO", "PARTIAL"]},
    {"name": "htf_context_available", "category": "data_quality", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["YES", "NO", "PARTIAL"]},
    {"name": "leakage_risk", "category": "data_quality", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["LOW", "MEDIUM", "HIGH", "UNKNOWN"]},
    {"name": "evidence_quality", "category": "data_quality", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["HIGH", "MEDIUM", "LOW", "UNUSABLE"]},
    {"name": "exclude_from_future_comparison", "category": "data_quality", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["YES", "NO"]},
    {"name": "exclusion_reason", "category": "data_quality", "required_column": true, "required_for_nonblank_row": false, "type": "text"}
  ],
  "completion_modes": {
    "RAPID_CAPTURE": {
      "description": "Quick manual entry during or shortly after seeing a trade. Only minimal viable fields are required. Missing full-review fields create warnings, not failures.",
