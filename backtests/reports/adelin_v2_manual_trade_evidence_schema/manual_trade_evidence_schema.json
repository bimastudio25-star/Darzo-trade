    {"name": "metadata_complete", "category": "data_quality", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["YES", "NO", "PARTIAL"]},
    {"name": "price_levels_visible", "category": "data_quality", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["YES", "NO", "PARTIAL"]},
    {"name": "timestamp_visible", "category": "data_quality", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["YES", "NO", "PARTIAL"]},
    {"name": "outcome_visible", "category": "data_quality", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["YES", "NO", "PARTIAL"]},
    {"name": "htf_context_available", "category": "data_quality", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["YES", "NO", "PARTIAL"]},
    {"name": "leakage_risk", "category": "data_quality", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["LOW", "MEDIUM", "HIGH", "UNKNOWN"]},
