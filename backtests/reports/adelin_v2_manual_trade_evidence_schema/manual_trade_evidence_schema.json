    {"name": "fvg_ifvg_present", "category": "context", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["YES", "NO", "UNCLEAR", "NOT_APPLICABLE"]},
    {"name": "target_space_clean", "category": "context", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["YES", "NO", "UNCLEAR", "NOT_APPLICABLE"]},
    {"name": "immediate_reaction_present", "category": "context", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["YES", "NO", "UNCLEAR", "NOT_APPLICABLE"]},
    {"name": "reaction_speed", "category": "context", "required_column": true, "required_for_nonblank_row": true, "type": "enum", "allowed_values": ["FAST", "SLOW", "CHOPPY", "NONE", "UNKNOWN", "NOT_APPLICABLE"]},

