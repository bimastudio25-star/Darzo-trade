  "leakage_warning": "Outcome screenshots may be recorded, but later comparisons must separate pre-entry context from post-entry outcome. Manual result labels are qualitative evidence only and must not be treated as validation.",
  "safety": {
    "ohlc_read": false,
    "replay_run": false,
    "matched_control_replay_run": false,
    "runtime_logic_modified": false,
    "phase_4_blocked": true,
    "live_trading_enabled": false,
    "telegram_enabled": false,
    "broker_execution_enabled": false,
    "profitability_claim_made": false
  }
