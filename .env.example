REENTRY_REQUIRE_CHOCH=true
REENTRY_REQUIRE_FVG_OR_IFVG=true
REENTRY_MAX_VOLATILITY_STATE=elevated
REENTRY_NO_CHASE_MAX_DISTANCE_PIPS=8

