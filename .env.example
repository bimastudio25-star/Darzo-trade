# =========================
# Runtime mode
# =========================
PAPER_MODE=true
DEMO_EXECUTION=false
LIVE_EXECUTION=false
ORDERFLOW_ENABLED=false
AI_ENABLED=true
TELEGRAM_ENABLED=true

# =========================
# Broker / MT5
# =========================
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=
MT5_SYMBOL=XAUUSD

# =========================
# Telegram
# =========================
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# =========================
# Anthropic
# =========================
ANTHROPIC_API_KEY=
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_DEEP_MODEL=claude-sonnet-4-20250514

# =========================
# OpenAI / ChatGPT API
# =========================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_AUDIT_MODEL=gpt-5.5

# =========================
# AI provider routing
# =========================
AI_FAST_PROVIDER=anthropic
AI_DEEP_PROVIDER=anthropic
AI_AUDIT_PROVIDER=openai

# =========================
# News / Macro
# =========================
NEWS_API_KEY=
TAVILY_API_KEY=
FRED_API_KEY=

# =========================
# Risk settings
# =========================
ACCOUNT_BALANCE=10000
RISK_PER_TRADE=0.005
MAX_DAILY_DRAWDOWN=0.02
MAX_DAILY_SIGNALS=5
MAX_CONSECUTIVE_LOSSES=3
MIN_RR=2.0
MAX_SPREAD_PIPS=3

# =========================
# Orderflow / DOM
# =========================
ORDERFLOW_PROVIDER=mt5_dom
ORDERFLOW_SYMBOL=XAUUSD
ORDERFLOW_CONFIDENCE_LEVEL=LOW

# =========================
# Storage
# =========================
LEDGER_DB_PATH=data/dazro_ledger.sqlite
LOG_LEVEL=INFO

# =========================
# Telegram alert policy
# =========================
SEND_WATCH_ALERTS=false
SEND_APPROACHING_ALERTS=false
SEND_ARMED_REACTION_ALERTS=false
SEND_SWEEP_INTRABAR_ALERTS=false
SEND_TRIGGERED_ONLY=true
MIN_REACTION_DISTANCE_PIPS=50
APPROACHING_ALERT_DISTANCE_PIPS=150
ARMED_ALERT_DISTANCE_PIPS=100
IMMINENT_REACTION_DISTANCE_PIPS=50
ALLOW_FAR_PREP_ALERTS=false
FAR_PREP_ALERT_DISTANCE_PIPS=300
MAX_FAR_PREP_ALERTS_PER_SESSION=1
REACTION_ALERT_COOLDOWN_MINUTES=20
MAX_ALERTS_PER_ZONE_PER_SESSION=3
MAX_REACTION_ALERTS_PER_SESSION=5

# =========================
# Target policy
# =========================
MIN_NORMAL_REACTION_TARGET_PIPS=50
PREFERRED_REACTION_TARGET_PIPS=100
ALLOW_VWAP_1R_TARGET=true
MIN_VWAP_TARGET_PIPS=30
MIN_RR_NORMAL=1.5
MIN_RR_VWAP_SCALP=1.0
MAX_OFFICIAL_TARGETS=3
ALLOW_RUNNER_TARGET=true
MIN_GAP_BETWEEN_OFFICIAL_TARGETS_PIPS=50
MIN_GAP_BETWEEN_SCALP_TARGETS_PIPS=30
TARGET_CLUSTER_TOLERANCE_PIPS=25
MIN_TP1_DISTANCE_PIPS=50
MIN_TP1_DISTANCE_PIPS_VWAP_SCALP=30
HIDE_MICRO_TARGETS=true
MAX_CANDIDATE_TARGETS_DEBUG=20
SHOW_THEORETICAL_PLAN_ON_WATCH=true
MAX_THEORETICAL_TARGETS_ON_WATCH=3
THEORETICAL_SL_BUFFER_PIPS=10
MIN_STOP_DISTANCE_PIPS=20
MAX_STOP_DISTANCE_PIPS=150
REACTION_CLUSTER_TOLERANCE_PIPS=100
REACTION_CLUSTER_COOLDOWN_MINUTES=10
MAX_CONFIRMED_SWEEP_ALERTS_PER_CLUSTER=1
NUMBER_THEORY_TOLERANCE_PIPS=1.2
NUMBER_THEORY_STRICT_PIPS=0.8
STATISTICAL_SCALP_ENABLED=false
STATISTICAL_SCALP_MAX_PER_SESSION=3
STATISTICAL_SCALP_MIN_ABS_Z=2.0
STATISTICAL_SCALP_BAND_TOLERANCE_PIPS=0.5

# =========================
# Adelin primary strategy
# =========================
ADELIN_ENABLED=true
ADELIN_MIN_SCORE=65
ADELIN_A_PLUS_SCORE=85
ADELIN_VWAP_MIN_SCORE=80
ADELIN_SL_MIN_PIPS=35
ADELIN_SL_MAX_PIPS=65
